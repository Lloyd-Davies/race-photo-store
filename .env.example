# Database
POSTGRES_PASSWORD=changeme

# Stripe — leave blank to run without payment (checkout/webhook return 503)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# App
PUBLIC_BASE_URL=https://photos.yourdomain.com
ADMIN_TOKEN=changeme-admin-token

# Cloudflare Tunnel — get this from the Cloudflare Zero Trust dashboard
# Dashboard -> Networks -> Tunnels -> your tunnel -> Configure -> "Install and run connector"
# Copy the token from the docker run command: --token <TOKEN>
CLOUDFLARE_TUNNEL_TOKEN=
