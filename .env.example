# Database
POSTGRES_PASSWORD=changeme

# Stripe — leave blank to run without payment (checkout/webhook return 503)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# App
PUBLIC_BASE_URL=https://photos.yourdomain.com
# Base admin credential used for /api/admin/login
ADMIN_TOKEN=changeme-admin-token
# Secret for signed admin access/refresh session tokens
ADMIN_SESSION_SECRET=changeme-admin-session-secret
# Admin session lifetimes
ADMIN_SESSION_TTL_MINUTES=30
ADMIN_REFRESH_TTL_HOURS=12
# Secrets and lifetimes for signed event/order access tokens
EVENT_ACCESS_SECRET=changeme-event-access-secret
EVENT_ACCESS_TTL_HOURS=12
ORDER_ACCESS_TTL_HOURS=720
# Max admin photo upload size (bytes)
MAX_PHOTO_UPLOAD_BYTES=26214400

# Branding
SITE_NAME=Race Photos
SITE_TAGLINE=Your race, your photos.

# Cloudflare Tunnel — get this from the Cloudflare Zero Trust dashboard
# Dashboard -> Networks -> Tunnels -> your tunnel -> Configure -> "Install and run connector"
# Copy the token from the docker run command: --token <TOKEN>
CLOUDFLARE_TUNNEL_TOKEN=
